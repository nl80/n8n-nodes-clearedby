{
  "name": "n8n-nodes-clearedby",
  "version": "0.1.1",
  "description": "n8n community node for ClearedBy — gate an action behind policy + human approval before your workflow proceeds.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "clearedby",
    "approval",
    "human-in-the-loop",
    "gate"
  ],
  "license": "MIT",
  "homepage": "https://clearedby.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nl80/n8n-nodes-clearedby.git"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-icons.mjs",
    "lint": "eslint nodes credentials package.json",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ClearedByApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/ClearedByGate/ClearedByGate.node.js",
      "dist/nodes/ClearedByTrigger/ClearedByTrigger.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-plugin-n8n-nodes-base": "^1.16.7",
    "jsonc-eslint-parser": "^2.4.2",
    "n8n-workflow": "*",
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
